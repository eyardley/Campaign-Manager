<div>
    <%= link_to "Back", campaigns_path %>
</div>

<h1 class="text-center mb-4"><%= @campaign.name %></h1>

<% if @campaign.character_sheet_template == nil %>
  <div class="row mb-4">
      <%= link_to "Add Character Sheet Template", new_campaign_character_sheet_template_path(@campaign) %>
  </div>
  <% else %>
  <div class="row mb-4">
      <%= link_to "View Character Sheet Template", campaign_character_sheet_template_path(@campaign, @campaign.character_sheet_template.id) %>
  </div>
<% end %>

<div class="row mb-4">
    <%= link_to "Invite Friends", new_campaign_campaign_invite_path(@campaign) %>
</div>

<div class="row mb-4">
    <div class="col">
        <%= render "shared/text_block",
          title: "Description",
          edit_path: edit_campaign_path(@campaign),
          field: @campaign.description,
          can_edit: @is_game_master %>
        <div class="row">
            <%= @campaign.description %>
        </div>
        <% if @is_game_master %>
            <%= render "shared/text_block",
              title: "Notes",
              edit_path: edit_campaign_path(@campaign),
              field: @campaign.notes,
              can_edit: @is_game_master %>
        <% end %>
    </div>
    <div class="col">
        <div class="text-center row">
            <%= image_tag @campaign.featured_image if @campaign.featured_image.attached? %>
        </div>
    </div>
</div>

<div class="row mb-md-4">
    <div class="col-md-6">
        <%= render "shared/table_list",
          table_title: "Locations",
          items: @campaign.locations,
          parent: @campaign,
          new_path:  new_campaign_location_path(@campaign),
          can_edit: @is_game_master %>
    </div>
    <div class="col-md-6">
        <%= render "shared/table_list",
          table_title: "NPCs",
          items: @campaign.non_player_characters,
          parent: @campaign,
          new_path:  new_campaign_non_player_character_path(@campaign),
          can_edit: @is_game_master %>
    </div>
</div>

<div class="row mb-md-4">
    <div class="col-md-6">
        <%= render "shared/table_list",
          table_title: "PCs",
          items: @campaign.player_characters,
          parent: @campaign,
          new_path:  new_campaign_player_character_path(@campaign),
          can_edit: @is_game_master %>
    </div>
</div>

<br>

<% if @is_game_master %>
    <div class="row">
        <div class="col-6 text-end">
            <%= link_to "Edit", [:edit, @campaign] %>
        </div>
        <div class="col-6">
            <%= button_to "Delete", @campaign, method: :delete, data: { turbo_confirm: "Are you sure?" } %>
        </div>
    </div>
    <br>
<% end %>

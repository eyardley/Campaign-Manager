<%= form_with model: [campaign, player_character, character_sheet],
    data: {
      controller: "character-sheet",
      action: "submit->character-sheet#serialize",
      "character-sheet-existing-fields-value": (character_sheet.data || {}).to_json
    } do |form| %>

    <% if form.object.errors.any? %>
        <p class="error"><%= form.object.errors.full_messages.first %></p>
    <% end %>

    <div class="row align-items-center">
        <div class="col">
            <h2>Fields</h2>
        </div>
    </div>
    <div data-character-sheet-target="fields"></div>

    <%= form.hidden_field :data, data: { "character-sheet-target": "data" } %>

    <div class="row mt-4">
        <div class="col-6 text-end">
            <%= form.submit class: "btn btn-primary" %>
        </div>
        <div class="col-6 mt-1">
            <%= link_to "javascript:history.back()" do %>
                Cancel
            <% end %>
        </div>
    </div>

<% end %>

<div class="card">
  <%= image_tag thumbnail_image %>
  <div class="card-body">
    <h5 class="card-title"><%= link_to item.name, [parent, item].compact %></h5>
    <p class="card-text"><%= short_description %></p>
    <% if can_edit %>
        <%= link_to "Edit", [:edit, parent, item] %>
    <% end %>
    <% if can_delete %>
        <%= button_to "Delete", [parent, item],
          method: :delete,
          data: { turbo_confirm: "Are you sure?" },
          class: "btn btn-sm btn-danger" %>
    <% end %>
  </div>
</div>

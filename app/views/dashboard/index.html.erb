<div class="row mb-md-4">
    <h1>Welcome to Campaign Manager</h1>
</div>

<div class="row mb-md-4">
    <div class="col-md-6">
        <%= render "shared/table_list",
          table_title: "Campaigns",
          items: @campaigns,
          parent: nil,
          new_path: new_campaign_path,
          can_edit: true %>
    </div>
    <div class="col-md-6">
        <div class="row align-items-center">
            <div class="col">
                <h2>Friends</h2>
            </div>
        </div>
        <div class="row">
            <div class="col">
                <table class="table table-striped">
                    <tbody>
                        <% @friendships.each do |friendship| %>
                            <tr>
                                <% friend = friendship.user == Current.user ? friendship.friend : friendship.user %>

                                <td><%= friend.email_address %></td>
                                <td class="text-end">
                                    <%= button_to "Remove", user_friendship_path(Current.user, friendship),
                                        method: :delete,
                                        data: { turbo_confirm: "Are you sure?" },
                                        class: "btn btn-sm btn-danger" %>
                                </td>
                            </tr>
                        <% end %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="row mb-md-4">
    <div class="col-md-6">
        <div class="row align-items-center">
            <div class="col">
                <h2>Friend Requests</h2>
            </div>
                <div class="col-auto mt-3">
                    <%= link_to "New Friend Request", new_user_friendship_path(Current.user.id) %>
                </div>
        </div>
        <div class="row">
            <div class="col">
                <table class="table table-striped">
                    <tbody>
                        <% @friend_requests.each do |request| %>
                            <tr>
                                <td><%= request.user.email_address %> sent you a friend request!</td>
                                <td class="text-end">
                                    <%= button_to "Accept", user_friendship_path(Current.user, request),
                                        method: :patch,
                                        params: { friendship: { status: "accepted" } },
                                        class: "btn btn-sm btn-success" %>

                                    <%= button_to "Decline", user_friendship_path(Current.user, request),
                                        method: :patch,
                                        params: { friendship: { status: "declined" } },
                                        class: "btn btn-sm btn-danger" %>
                                </td>
                            </tr>
                        <% end %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="col-md-6">
            <div class="row align-items-center">
                <div class="col">
                    <h2>Campaign Invites</h2>
                </div>
            </div>
            <div class="row">
                <div class="col">
                    <table class="table table-striped">
                        <tbody>
                            <% @campaign_invites.each do |invite| %>
                                <tr>
                                    <td>You have been invited to join <%= invite.campaign.name %>!</td>
                                    <td class="text-end">
                                    <td class="text-end">
                                        <%= button_to "Accept", campaign_campaign_invite_path(invite.campaign_id, invite.id),
                                            method: :patch,
                                            params: { CampaignInvite: { status: "accepted" } },
                                            class: "btn btn-sm btn-success" %>

                                        <%= button_to "Decline", campaign_campaign_invite_path(invite.campaign_id, invite.id),
                                            method: :patch,
                                            params: { CampaignInvite: { status: "declined" } },
                                            class: "btn btn-sm btn-danger" %>
                                    </td>
                                    </td>
                                </tr>
                            <% end %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<%= form_with model: [campaign, non_player_character] do |form| %>
    <%= render layout: 'shared/form_fields', locals: { form: form } do %>
        <div class="mb-md-4">
            <%= form.label "Related locations", class: "form-label" %>
            <%= form.collection_checkboxes :related_location_ids, @campaign.locations, :id, :name %>
        </div>

        <div class="mb-md-4">
            <%= form.label "Related Npcs", class: "form-label" %>
            <%= form.collection_checkboxes :related_npc_ids, @campaign.non_player_characters.select{|npc| npc != @npc}, :id, :name %>
        </div>
    <% end %>
<% end %>
